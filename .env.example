# BoonBuy AI / site (copy to .env.local — never commit secrets)

# Vercel AI Gateway (required for LLM chat; catalogue search works without it)
AI_GATEWAY_API_KEY=
# Validated model ids — defaults applied when empty/invalid
AI_PRIMARY_MODEL=openai/gpt-4o-mini
AI_FALLBACK_MODEL=openai/gpt-4o
AI_EMBEDDING_MODEL=

# Limits (optional)
AI_MAX_OUTPUT_TOKENS=1200
AI_DAILY_REQUEST_LIMIT=800
AI_RATE_LIMIT_PER_MINUTE=12
AI_RATE_LIMIT_PER_DAY=80
AI_MAX_HISTORY_MESSAGES=16
AI_MAX_PROMPT_CHARS=1200
AI_MAX_TOOL_CALLS=6
AI_MAX_PRODUCTS=12

# Cron protection for /api/ai/cron/* — REQUIRED in production
CRON_SECRET=

# Public site URL
NEXT_PUBLIC_SITE_URL=https://boonbuyfinds.net
